DISCORD_BOT_TOKEN=dein-bot-token-hier
DISCORD_APPLICATION_ID=deine-application-id-hier

# Optional: für Slash-Command-Tests auf einem Dev-Server.
# Wenn gesetzt UND in src/handlers/loadCommands.js die kommentierte Zeile
# aktiviert wird, registrieren sich Commands instant statt global.
# DEV_GUILD_ID=

# AI Ticket Assistant (Open WebUI, OpenAI-kompatibel).
# Pflicht, sonst bleibt das Feature inaktiv:
OPENWEBUI_BASE_URL=https://example.com/api
OPENWEBUI_API_KEY=

# Optional, Defaults stehen in src/config.js:
# GATE_MODEL=pact-gate
# ANSWER_MODEL=pact-answer
# OPENWEBUI_TIMEOUT_MS=30000
# TICKET_ASSISTANT_ENABLED=true
# TICKET_ASSISTANT_VERBOSE=true
# DEBOUNCE_SECONDS=4
# MAX_AUTO_REPLIES=5

# ID-Overrides nur fürs lokale Testen (sonst Defaults aus config.js), kommagetrennt:
# TICKET_CATEGORY_IDS=
# SUPPORT_ROLE_IDS=
